  m_Script: {fileID: 11500000, guid: 90fb8c1d477611e4fb804a8c2b15634e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ObjetoRecuerdo
  titulo: Foto de Chucky
  descripcion: "La foto de Chucky. La cog\xED y se me escap\xF3 una sonrisa. Me acord\xE9
    de mam\xE1 en la cocina, con \xE9l pegado a sus talones como siempre. Esperaba
    paciente mientras ella pochaba la cebolla... pero en cuanto ve\xEDa el pimiento,
    se sentaba recto como un palo. Y cuando llegaba la berenjena justo despu\xE9s,
    ya no hab\xEDa quien lo moviera de all\xED. Como si supiera que ese era el coraz\xF3n
    de todo."
  imagen: {fileID: 2479515761107150947, guid: 8c18bd46550a6034089f7259dd250853, type: 3}
  escena: Cocina
  esPista: 1
  interactuableID: 13
