  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 90fb8c1d477611e4fb804a8c2b15634e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ObjetoRecuerdo
  titulo: "Delantal de mam\xE1"
  descripcion: "El delantal de mam\xE1. Lo cog\xED y cerr\xE9 los ojos. Me vino el
    olor a ajo reci\xE9n machacado llenando la cocina... y luego ella rompi\xE9ndome
    un huevo en la sart\xE9n cuando ya casi estaba listo, gui\xF1\xE1ndome un ojo.
    \"El secreto est\xE1 en el principio y en el final\", me dec\xEDa siempre."
  imagen: {fileID: -1879856633, guid: 8c18bd46550a6034089f7259dd250853, type: 3}
  escena: Cocina
  esPista: 1
  interactuableID: 12
