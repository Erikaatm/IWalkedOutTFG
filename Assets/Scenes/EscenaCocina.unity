--- !u!1001 &490379912056235039
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1351410512}
    m_Modifications:
    - target: {fileID: 3014645448736864648, guid: 2f4093f5142b5934fbe90320cb47b37e, type: 3}
      propertyPath: descripcion
      value: "La mesa de los domingos. Cinco platos, pan, algo caliente, algo fr\xEDo.
        Lua siempre se sub\xEDa a la silla de rodillas aunque no deb\xEDa. Pap\xE1
        miraba para otro lado. Mam\xE1 llenaba los vasos sin que nadie se los pidiera.
        Yo pon\xEDa la m\xFAsica. No s\xE9 cu\xE1ndo dejamos de hacer eso."
      objectReference: {fileID: 0}
    - target: {fileID: 3014645448736864648, guid: 2f4093f5142b5934fbe90320cb47b37e, type: 3}
