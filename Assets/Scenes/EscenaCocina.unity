  m_Script: {fileID: 11500000, guid: 90fb8c1d477611e4fb804a8c2b15634e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ObjetoRecuerdo
  titulo: La nevera
  descripcion: "Abr\xED la nevera y me qued\xE9 paralizado. Ah\xED estaba el tupper
    de cristal de siempre, con el pisto dentro. Lo hab\xEDa hecho esa tarde, antes
    de irse al festival. Con una nota pegada encima con celo: 'Para cuando vuelvas,
    que llegar\xE1s con hambre. Cali\xE9ntalo bien y no te saltes el pan.' Se fueron
    sin m\xED. Y yo nunca abr\xED ese tupper."
  imagen: {fileID: -927847424, guid: 8c18bd46550a6034089f7259dd250853, type: 3}
  escena: Cocina
  esPista: 0
  interactuableID: 11
