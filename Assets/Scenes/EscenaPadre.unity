      propertyPath: escena
      value: Padre
      objectReference: {fileID: 0}
    - target: {fileID: 6495817451768696926, guid: 20c81fbcc067214478c2a63994904012, type: 3}
      propertyPath: titulo
      value: Trozo de papel
      objectReference: {fileID: 0}
    - target: {fileID: 6495817451768696926, guid: 20c81fbcc067214478c2a63994904012, type: 3}
      propertyPath: descripcion
      value: "Una hoja de papel pautado doblada en cuatro. Con la letra de pap\xE1,
        apresurada como siempre. \"Sol, Mi, Sol, La, Sol, Fa. Llevo semanas d\xE1ndole
        vueltas y esta ma\xF1ana simplemente lo supe. Son las primeras notas que
        te ense\xF1\xE9 de peque\xF1o. Te sentaste en el taburete, puse tus dedos
        en las teclas y te re\xEDste porque hac\xEDan ruido. Me pareci\xF3 bien empezar
        por ah\xED."
      objectReference: {fileID: 0}
    - target: {fileID: 6495817451768696926, guid: 20c81fbcc067214478c2a63994904012, type: 3}
      propertyPath: interactuableID
      value: 21
      objectReference: {fileID: 0}
