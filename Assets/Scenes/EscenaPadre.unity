  m_Script: {fileID: 11500000, guid: 90fb8c1d477611e4fb804a8c2b15634e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ObjetoRecuerdo
  titulo: Chimenea
  descripcion: "La chimenea encendida. Como siempre. Pap\xE1 la encend\xEDa cada
    noche aunque no hiciera fr\xEDo. Yo me quedaba en el suelo con los deberes, \xE9l
    en el sill\xF3n con alguna partitura. Ninguno dec\xEDa nada y eso estaba bien.
    Ojal\xE1 le hubiera dicho que eso era lo que m\xE1s echaba de menos. No la m\xFAsica.
    Era eso. El fuego. El silencio. \xC9l al lado."
  imagen: {fileID: 5003329022577973082, guid: 0eb0488d9fe583040939f185a7081967, type: 3}
  escena: Padre
  esPista: 0
  interactuableID: 25
